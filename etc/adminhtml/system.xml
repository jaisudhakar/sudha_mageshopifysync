<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="sudha" translate="label" sortOrder="400">
            <label>Sudha Extensions</label>
        </tab>
        <section id="sudha_mageshopifysync" translate="label" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Mage Shopify Sync</label>
            <tab>sudha</tab>
            <resource>Sudha_Mageshopifysync::config</resource>

            <!-- General -->
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enable or disable the Mage Shopify Sync module.</comment>
                </field>
            </group>

            <!-- Shopify API -->
            <group id="shopify" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Shopify API Settings</label>
                <field id="store_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Shopify Store URL</label>
                    <comment>e.g. your-store.myshopify.com (without https://)</comment>
                    <validate>required-entry</validate>
                </field>
                <field id="api_key" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Key</label>
                    <comment>Your Shopify Admin API access token.</comment>
                    <validate>required-entry</validate>
                </field>
                <field id="api_secret" translate="label comment" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>API Secret</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Stored encrypted in the database.</comment>
                </field>
                <field id="api_version" translate="label" type="text" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Version</label>
                    <comment>Shopify API version, e.g. 2024-01</comment>
                </field>
            </group>

            <!-- Alert Settings -->
            <group id="alert" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Delay Alert Settings</label>
                <field id="threshold_days" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Delay Threshold (Days)</label>
                    <comment>Alert admin when a Shopify order stays in transit for more than this many days.</comment>
                    <validate>required-entry validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="alert_email" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Alert Email Address</label>
                    <comment>Email address to receive delay alerts. Defaults to store admin email if empty.</comment>
                    <validate>validate-email</validate>
                </field>
                <field id="cron_schedule" translate="label comment" type="text" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Cron Schedule</label>
                    <comment>Cron expression for how often to check for delayed shipments. Default: daily at 8am.</comment>
                </field>
            </group>

        </section>
    </system>
</config>
